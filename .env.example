# Environment Configuration
# Copy to .env and fill in values

# ─── General ───
APP_ENV=development
APP_NAME=atlas
LOG_LEVEL=debug

# ─── API Gateway ───
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Auth Service ───
AUTH_SERVICE_PORT=8001
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_COST=12

# ─── User Service ───
USER_SERVICE_PORT=8002

# ─── KYC Service ───
KYC_SERVICE_PORT=8003

# ─── Compliance Service ───
COMPLIANCE_SERVICE_PORT=8004

# ─── Account Service ───
ACCOUNT_SERVICE_PORT=8005

# ─── Ledger Service ───
LEDGER_SERVICE_PORT=8006

# ─── Transaction Service ───
TRANSACTION_SERVICE_PORT=8007

# ─── Transfer Service ───
TRANSFER_SERVICE_PORT=8008

# ─── Exchange Service ───
EXCHANGE_SERVICE_PORT=8009

# ─── Card Service ───
CARD_SERVICE_PORT=8010

# ─── Wallet Service ───
WALLET_SERVICE_PORT=8011

# ─── Blockchain Service ───
BLOCKCHAIN_SERVICE_PORT=8012

# ─── Loan Service ───
LOAN_SERVICE_PORT=8013

# ─── Savings Service ───
SAVINGS_SERVICE_PORT=8014

# ─── Notification Service ───
NOTIFICATION_SERVICE_PORT=8015

# ─── Analytics Service ───
ANALYTICS_SERVICE_PORT=8016

# ─── Audit Service ───
AUDIT_SERVICE_PORT=8017

# ─── PostgreSQL ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_SSL_MODE=disable

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Kafka ───
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=atlas

# ─── OpenSearch ───
OPENSEARCH_URL=http://localhost:9200

# ─── S3 Storage ───
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=atlas
S3_REGION=us-east-1

# ─── SMTP ───
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ─── Push Notifications ───
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# ─── Observability ───
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8080
